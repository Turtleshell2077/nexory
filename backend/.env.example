# ───────── Сервер ─────────
PORT=3000
NODE_ENV=production

# ───────── PostgreSQL ─────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexory
DB_USER=nexory_user
DB_PASSWORD=CHANGE_ME

# ───────── JWT (ОБЯЗАТЕЛЬНО сменить в проде!) ─────────
JWT_ACCESS_SECRET=CHANGE_ME_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_another_long_random_string

# ───────── CORS / прокси ─────────
# Разрешённые origin через запятую, или * для всех
CORS_ORIGINS=*
# За обратным прокси (nginx) укажите число хопов, чтобы rate limit видел реальный IP
# TRUST_PROXY=1

# ───────── HTTPS (опционально) ─────────
# Пути к сертификатам (Let's Encrypt). Если заданы — сервер поднимется по HTTPS/WSS.
# SSL_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem

# ───────── SMTP (письма: коды подтверждения, сброс пароля, поддержка) ─────────
# ВАЖНО: порт 465 → SSL, порт 587 → STARTTLS (сервер сам ставит secure по порту).
# Пароль — это "пароль приложения" из настроек почты, НЕ обычный пароль аккаунта.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=you@example.com
# SMTP_PASS=app_password_from_mail_settings
# SMTP_FROM="Nexory <you@example.com>"
# SUPPORT_EMAIL=you@example.com   # куда приходят обращения из поддержки

# ───────── FCM push (опционально) ─────────
# FCM_SERVICE_ACCOUNT_PATH=./config/fcm-service-account.json
